# ============================================================================
# LENDSWIFT AI - BACKEND CONFIGURATION
# ============================================================================
# Security and OTP Authentication Setup

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
# Set these to strong random values in production
LENDSWIFT_SECRET_KEY=lendswift-dev-secret-key-change-in-production
LENDSWIFT_AES_KEY=lendswift-aes-key-change-in-production

# ============================================================================
# SMS PROVIDER CONFIGURATION
# ============================================================================
# Options: 
#   - "console" (development - prints OTP to terminal)
#   - "twilio" (production - uses Twilio SMS)
#   - "fast2sms" (production - recommended for India)

SMS_PROVIDER=console

# --- TWILIO CONFIGURATION ---
# For production use with real SMS delivery
# Sign up: https://www.twilio.com
# Dashboard: https://console.twilio.com
# Get your credentials from the console
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1234567890

# --- FAST2SMS CONFIGURATION (Recommended for India) ---
# For production SMS delivery in India
# Sign up: https://www.fast2sms.com
# Get API key from dashboard
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# ============================================================================
# OTP CONFIGURATION
# ============================================================================
# OTP expiry time in seconds (default: 5 minutes = 300 seconds)
OTP_EXPIRATION_SECONDS=300

# Maximum number of OTP verification attempts before lockout
OTP_MAX_ATTEMPTS=3

# Maximum OTP requests per hour per mobile number
OTP_MAX_REQUESTS_PER_HOUR=5

# Cooldown time before allowing resend in seconds (default: 30 seconds)
OTP_RESEND_COOLDOWN_SECONDS=30

# ============================================================================
# AUTHENTICATION CONFIGURATION
# ============================================================================
# Minimum password length
PASSWORD_MIN_LENGTH=8

# Maximum failed login attempts before account lock
LOGIN_MAX_ATTEMPTS=5

# Account lock duration in seconds (default: 15 minutes = 900 seconds)
LOCK_DURATION_SECONDS=900

# ============================================================================
# DEPLOYMENT INSTRUCTIONS
# ============================================================================

# FOR DEVELOPMENT (Current):
# - SMS_PROVIDER=console
# - OTP will be printed to terminal/logs
# - Perfect for local testing

# FOR PRODUCTION WITH TWILIO:
# 1. Sign up at https://www.twilio.com
# 2. Get TWILIO_ACCOUNT_SID from console
# 3. Get TWILIO_AUTH_TOKEN from console  
# 4. Get TWILIO_FROM_NUMBER (your Twilio phone number)
# 5. Set SMS_PROVIDER=twilio
# 6. Use HTTPS in production (secure=True in cookies)

# FOR PRODUCTION WITH FAST2SMS (Recommended for India):
# 1. Sign up at https://www.fast2sms.com
# 2. Get FAST2SMS_API_KEY from dashboard
# 3. Set SMS_PROVIDER=fast2sms
# 4. Use HTTPS in production (secure=True in cookies)

# CRITICAL SECURITY NOTES:
# 1. NEVER commit this file to git if it has real credentials
# 2. Add .env to .gitignore
# 3. Use environment variables in production (AWS Secrets, etc.)
# 4. Rotate API keys regularly
# 5. Monitor SMS delivery logs
# 6. Implement rate limiting on OTP endpoints
# 7. Use HTTPS in production
