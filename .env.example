# LendSwift Backend Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
# Set these to strong random values in production
LENDSWIFT_SECRET_KEY=dev-only-change-this-secret-key-to-something-secure
LENDSWIFT_AES_KEY=dev-only-change-this-aes-key-to-something-secure

# ============================================================================
# SMS PROVIDER CONFIGURATION
# ============================================================================
# Options: console (development), twilio, fast2sms
SMS_PROVIDER=console

# --- TWILIO CONFIGURATION ---
# Sign up at: https://www.twilio.com
# Get credentials from: https://console.twilio.com
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1234567890

# --- FAST2SMS CONFIGURATION (Recommended for India) ---
# Sign up at: https://www.fast2sms.com
# Get API key from dashboard
FAST2SMS_API_KEY=your_api_key_here

# ============================================================================
# OTP CONFIGURATION
# ============================================================================
OTP_EXPIRATION_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_MAX_REQUESTS_PER_HOUR=5
OTP_RESEND_COOLDOWN_SECONDS=30

# ============================================================================
# AUTHENTICATION CONFIGURATION
# ============================================================================
PASSWORD_MIN_LENGTH=8
LOGIN_MAX_ATTEMPTS=5
LOCK_DURATION_SECONDS=900

# ============================================================================
# PRODUCTION DEPLOYMENT NOTES
# ============================================================================
# 1. Set SMS_PROVIDER=twilio or SMS_PROVIDER=fast2sms (not console)
# 2. Configure appropriate SMS provider credentials above
# 3. Use strong, random values for LENDSWIFT_SECRET_KEY and LENDSWIFT_AES_KEY
# 4. Deploy behind HTTPS in production
# 5. Implement proper environment variable management (AWS Secrets Manager, etc.)
# 6. Enable CSRF protection and use secure cookies
# 7. Monitor SMS delivery logs and OTP failure rates
# 8. Implement rate limiting for OTP endpoints
